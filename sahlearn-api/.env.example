NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/sahlearn?appName=Cluster0
JWT_SECRET=<32-plus-random-characters>
JWT_EXPIRES_IN=7d
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>
CORS_ORIGIN=https://sahlearn.com,https://www.sahlearn.com,http://localhost:5173
ADMIN_SEED_EMAIL=admin@sahlearn.com
ADMIN_SEED_PASSWORD=<strong-password-change-after-first-login>
